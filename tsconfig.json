{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "allowJs": false,
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "api",
    "server.ts",
    "backend/server.ts",
    "backend/server.impl.ts",
    "backend/api"
  ],
  "exclude": ["frontend", "mobile"]
}
