# EAS upload (monorepo root). Excludes app folders that are not needed for the Expo Android app.
# Local Windows staging (eas-build-temp.ps1) uses packages/mobile/; set Expo Project root to packages/mobile.
# See https://docs.expo.dev/build-reference/easignore/

# Baseline (match .gitignore)
node_modules/
.expo/
build/
dist/
coverage/
.DS_Store
.env
.env*
!.env.example
*.log

# Monorepo: not part of the mobile app bundle
backend/
frontend/
sql/

# Duplicated in mobile/ — root copy not needed
/shared/

# VCS (large; EAS does not need full history in the upload)
.git/

# Tooling
.cursor/
.idea/
.vscode/

# Stray root native project only (leading slash = repo root, not mobile/android)
/android/

eas-archive-inspect/

# mobile native build caches (EAS can regenerate)
mobile/android/.gradle/
mobile/android/.kotlin/
mobile/android/app/build/
mobile/android/build/
mobile/android/.cxx/
mobile/android/app/.cxx/
mobile/android/local.properties
mobile/ios/

# Same native caches when app is staged as packages/mobile/ (Windows EAS staging script)
packages/mobile/android/.gradle/
packages/mobile/android/.kotlin/
packages/mobile/android/app/build/
packages/mobile/android/build/
packages/mobile/android/.cxx/
packages/mobile/android/app/.cxx/
packages/mobile/android/local.properties
packages/mobile/ios/

npm-debug.*
yarn-debug.*
yarn-error.*
