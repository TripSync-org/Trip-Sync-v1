# ── Supabase (free at supabase.com — open source, self-hostable) ─────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co
# Project Settings → API → service_role (secret — backend only, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ── Frontend / Mobile also need these (safe to expose, limited permissions) ───
# Project Settings → API → anon key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ── Auth secret (replace getAuthContext with your real auth when ready) ───────
AUTH_SECRET=any-random-string-you-make-up-yourself
# ── No other keys needed. WebRTC uses free Google STUN — zero signup. ─────────
