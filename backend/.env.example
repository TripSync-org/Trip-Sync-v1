# ── Supabase (free at supabase.com — open source, self-hostable) ─────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co
# Project Settings → API → service_role (secret — backend only, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ── Frontend / Mobile also need these (safe to expose, limited permissions) ───
# Project Settings → API → anon key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ── Auth secret (replace getAuthContext with your real auth when ready) ───────
AUTH_SECRET=any-random-string-you-make-up-yourself
# ── PayU (India) — server-only; never expose salt in the mobile app ────────────
PAYU_MERCHANT_KEY=your_merchant_key
PAYU_MERCHANT_SALT=your_merchant_salt
PAYU_BASE_URL=https://test.payu.in
# Production: https://secure.payu.in
PLATFORM_FEE_PERCENT=10
# Public URL PayU redirects to (surl/furl) — must match how phones reach your API
BACKEND_URL=http://localhost:3000
# Manual payout admin: POST /api/admin/payout/:id/update
ADMIN_SECRET_KEY=your-random-admin-secret

# ── No other keys needed. WebRTC uses free Google STUN — zero signup. ─────────
