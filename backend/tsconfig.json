{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "allowJs": false,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["api/**/*.ts", "server.ts", "server.impl.ts", "src/**/*.ts", "livetripmap/**/*.ts"]
}

