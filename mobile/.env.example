############################################
# Trip-Sync mobile (Expo) — copy to `.env`  #
############################################
#
# Same secrets as the repo root `.env`, but Expo requires the prefix EXPO_PUBLIC_
# (instead of VITE_). Copy each value from the matching line in root `.env`:
#
#   Root (.env)                      Mobile (.env) — use identical values
#   ------------------------------   ----------------------------------------
#   (not in root — mobile only)      EXPO_PUBLIC_API_URL  ← REQUIRED for login/API (see section below)
#   VITE_SUPABASE_URL                EXPO_PUBLIC_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY           EXPO_PUBLIC_SUPABASE_ANON_KEY
#   VITE_SUPABASE_PUBLISHABLE_KEY    EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY (optional)
#   VITE_MAPPLS_MAP_TOKEN            EXPO_PUBLIC_MAPPLS_MAP_TOKEN
#
# Do NOT put server-only keys here (SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DB_URL).
# Those stay in the root `.env` for `npm run dev` only.
#
# After editing: restart Metro (`npm run expo` or `npm run expo:clear` from repo root).
#

############################################
# API (Express — run `npm run dev` at repo root)
############################################
# Login and /api/* calls use this URL. It is NOT in the root .env — set it only here.
#
# Physical phone: localhost = the phone itself → "Network request failed". You MUST use your
# computer's Wi‑Fi address, e.g. EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
# (find it: Windows `ipconfig`, same Wi‑Fi as the phone, firewall allows port 3000).
#
# iOS Simulator:     http://localhost:3000
# Android Emulator:  http://10.0.2.2:3000
# Physical device:   http://<YOUR_PC_LAN_IP>:3000

EXPO_PUBLIC_API_URL=http://localhost:3000

############################################
# Supabase configuration (Expo / public)   #
############################################
# Mirror of root "Supabase configuration (frontend / Vite)" — use same values as VITE_* lines.

EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# JWT "anon" "public" key — same as VITE_SUPABASE_ANON_KEY in root `.env`.
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# Optional: same as VITE_SUPABASE_PUBLISHABLE_KEY if you use publishable instead of anon.
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

###################################
# Supabase — server-only (not used)
###################################
# The mobile app does not read these. Listed only so this file lines up with root `.env`.
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_DB_URL → keep in repo root `.env` only.

###################################
# Map provider
###################################
# Same value as VITE_MAPPLS_MAP_TOKEN in root `.env` if needed.
# EXPO_PUBLIC_MAPPLS_MAP_TOKEN=""
