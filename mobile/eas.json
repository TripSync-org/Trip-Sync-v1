{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false,
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_URL": "https://your-deployed-backend-url.vercel.app"
      },
      "releaseChannel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://your-deployed-backend-url.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
