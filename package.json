{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "mobile": "npm run expo:start --prefix mobile",
    "expo": "npm run expo:start --prefix mobile",
    "expo:clear": "npm run expo:start --prefix mobile -- --clear",
    "expo:android": "npm run run:android --prefix mobile",
    "expo:tunnel": "npm run expo:tunnel --prefix mobile",
    "frontend:dev": "vite --config frontend/vite.config.js",
    "backend:dev": "tsx backend/server.ts",
    "dev": "tsx backend/server.ts",
    "build": "vite build --config frontend/vite.config.js",
    "vercel-build": "node -e \"console.log('API-only deploy: skipping Vite'); process.exit(0)\"",
    "preview": "vite preview --config frontend/vite.config.js",
    "build:preview": "npm run build:preview --prefix mobile",
    "build:prod": "npm run build:prod --prefix mobile",
    "eas:android": "cd mobile && npx eas-cli@latest build --platform android --profile preview",
    "eas:android:production": "cd mobile && npx eas-cli@latest build --platform android --profile production",
    "clean": "rm -rf dist",
    "lint": "tsc -p backend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@supabase/supabase-js": "^2.99.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "~54.0.27",
    "expo-image-picker": "^55.0.19",
    "expo-location": "^55.1.8",
    "expo-print": "^55.0.13",
    "expo-sharing": "^55.0.18",
    "expo-status-bar": "^55.0.5",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-incall-manager": "^4.2.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-webrtc": "^124.0.7",
    "react-native-webview": "^13.16.1",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.22",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
