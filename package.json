{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "mobile": "npm run expo:start --prefix mobile",
    "expo": "npm run expo:start --prefix mobile",
    "expo:clear": "npm run expo:start --prefix mobile -- --clear",
    "expo:tunnel": "npm run expo:tunnel --prefix mobile",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "backend:dev": "tsx backend/server.ts",
    "dev": "tsx backend/server.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/vite": "^4.1.14",
